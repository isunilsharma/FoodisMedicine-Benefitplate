# BenefitPlate Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URL="mongodb://localhost:27017"
DB_NAME="benefitplate"

# CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000"

# OpenAI API key for LLM-powered explanations
OPENAI_API_KEY=your_openai_api_key_here

# LLM model to use (default: gpt-4o)
LLM_MODEL=gpt-4o

# OAuth service URL for session exchange
AUTH_SERVICE_URL=your_auth_service_url_here

# Admin email address (this user gets admin privileges)
ADMIN_EMAIL=admin@example.com
